<p id="notice"><%= notice %></p>

<div class="d-flex gap-3 align-items-center mb-3">
  <%= link_to "Download CSV", export_csv_accounting_lists_path, class: "btn btn-outline-primary" %>

  <%= form_with url: import_csv_accounting_lists_path, multipart: true, method: :post, local: true do |f| %>
    <div class="d-flex gap-2 align-items-center">
      <%= f.file_field :file, accept: ".csv", class: "form-control" %>
      <%= f.submit "Upload CSV", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

  <div class="card">
    <div class="card-body">
      <h2 class="card-title fw-bold">Accounting Lists</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Accounting type</th>
            <!-- <th>Vendor</th> -->
            <!-- <th>Amount</th> -->
            <th>Notes</th>
            <th colspan="3"></th>
          </tr>
        </thead>

        <tbody>
          <% @accounting_lists.each do |accounting_list| %>
            <tr>
              <td><%= accounting_list.accounting_type %></td>
              <!-- <td><%= accounting_list.vendor %></td> -->
              <!-- <td><%= accounting_list.amount %></td> -->
              <td><%= accounting_list.notes %></td>
              <td><%= link_to 'Show', accounting_list %></td>
              <td><%= link_to 'Edit', edit_accounting_list_path(accounting_list) %></td>
              <td><%= link_to 'Delete', accounting_list, method: :delete, data: { confirm: 'Are you sure?' } %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <br>
      <%= link_to 'New Accounting List', new_accounting_list_path %>
    </div>
  </div>
